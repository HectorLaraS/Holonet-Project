#-------------------------------------------------------
# API Settings
#-------------------------------------------------------

API_TIMEOUT_SECONDS=30
API_RETRY_COUNT=3
API_PAGE_SIZE=50

#-------------------------------------------------------
# Export
#-------------------------------------------------------

EXPORT_FOLDER=exports

#-------------------------------------------------------
# Logging
#-------------------------------------------------------

LOG_LEVEL=INFO
LOG_FOLDER=logs


#-------------------------------------------------------
# LogSchedulerging
#-------------------------------------------------------

# --------------------------------------------------
# Production:
#   Poll    = 300 seconds (5 minutes)
#   Report  = 43200 seconds (12 hours)
#   History = 86400 seconds (24 hours)
#
# Suggested testing:
#   Poll    = 60 seconds
#   Report  = 120 seconds
#   History = 120 seconds
# --------------------------------------------------

POLL_INTERVAL_SECONDS=60
REPORT_INTERVAL_SECONDS=120
REPORT_HISTORY_INTERVAL_SECONDS=120

GENERATE_REPORT_ON_STARTUP=false
RUN_POLL_ON_STARTUP=true

# Windows Service
SERVICE_RESTART_DELAY_SECONDS=5

# --------------------------------------------------
# History
# --------------------------------------------------

# Number of previous billing cycles requested from
# the Starlink API.
#
# Total billing cycles analyzed will be:
# Current Billing Cycle + BILLING_CYCLES_HISTORY
#
# Example:
# BILLING_CYCLES_HISTORY=4
# -> Current + Previous 4 = 5 Billing Cycles
#
BILLING_CYCLES_HISTORY=4